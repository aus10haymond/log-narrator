{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Log Narrator Report Schema",
  "description": "JSON schema for log analysis reports generated by log-narrator",
  "version": 1,
  "type": "object",
  "required": ["schema_version", "metadata", "summary", "statistics"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "description": "Version of this schema format",
      "const": 1
    },
    "metadata": {
      "type": "object",
      "required": ["title", "generated_at"],
      "properties": {
        "title": {
          "type": "string",
          "description": "Report title"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when report was generated (ISO 8601)"
        },
        "log_start_time": {
          "type": "string",
          "format": "date-time",
          "description": "Start time of analyzed logs (ISO 8601)"
        },
        "log_end_time": {
          "type": "string",
          "format": "date-time",
          "description": "End time of analyzed logs (ISO 8601)"
        }
      }
    },
    "summary": {
      "type": "array",
      "description": "Executive summary bullets",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "description": "Summary bullet point text"
          }
        }
      }
    },
    "statistics": {
      "type": "object",
      "required": ["total_events", "error_count", "warning_count"],
      "properties": {
        "total_events": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of events analyzed"
        },
        "error_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of ERROR severity events"
        },
        "warning_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of WARNING severity events"
        }
      }
    },
    "timeline": {
      "type": "array",
      "description": "Key timeline highlights",
      "items": {
        "type": "object",
        "required": ["timestamp", "description", "severity", "event_id"],
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Event timestamp (ISO 8601)"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of the event"
          },
          "severity": {
            "type": "string",
            "enum": ["DEBUG", "INFO", "NOTICE", "WARNING", "ERROR", "CRITICAL", "ALERT", "EMERGENCY", "UNKNOWN"],
            "description": "Event severity level"
          },
          "event_id": {
            "type": "integer",
            "minimum": 0,
            "description": "Unique event identifier"
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "description": "Analysis findings from rules engine",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "confidence", "description"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique finding identifier"
          },
          "title": {
            "type": "string",
            "description": "Short finding title"
          },
          "severity": {
            "type": "string",
            "enum": ["INFO", "LOW", "MEDIUM", "HIGH", "CRITICAL"],
            "description": "Finding severity level"
          },
          "confidence": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "Confidence score (0-100)"
          },
          "description": {
            "type": "string",
            "description": "Detailed finding description"
          },
          "evidence": {
            "type": "array",
            "description": "Supporting evidence event IDs",
            "items": {
              "type": "integer",
              "minimum": 0
            }
          },
          "tags": {
            "type": "object",
            "description": "Additional finding metadata",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "description": "Evidence excerpts referenced by findings",
      "items": {
        "type": "object",
        "required": ["event_id", "source_ref", "text"],
        "properties": {
          "event_id": {
            "type": "integer",
            "minimum": 0,
            "description": "Event identifier"
          },
          "source_ref": {
            "type": "string",
            "description": "Source location (e.g., 'app.log:123')"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Event timestamp (ISO 8601)"
          },
          "severity": {
            "type": "string",
            "description": "Event severity level"
          },
          "text": {
            "type": "string",
            "description": "Raw log text excerpt"
          }
        }
      }
    }
  }
}
